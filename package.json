{
  "name": "sentinel",
  "version": "0.4.3",
  "description": "A local-first desktop system monitor built with Electron, React, and TypeScript",
  "main": "./out/main/index.js",
  "author": "Drippyz1",
  "license": "MIT",
  "homepage": "https://github.com/Drippyz1/sentinel",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Drippyz1/sentinel.git"
  },
  "bugs": {
    "url": "https://github.com/Drippyz1/sentinel/issues"
  },
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint --cache .",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "verify:version": "node scripts/release/verify-version.cjs",
    "verify:diff": "git diff --check",
    "verify": "npm run lint && npm run typecheck && npm run build && npm run verify:version && npm run verify:diff",
    "verify:mac": "node scripts/release/verify-mac-app.cjs",
    "verify:mac:release": "node scripts/release/verify-mac-app.cjs --strict-release",
    "release:check-env": "node scripts/release/check-release-env.cjs",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "build": "npm run typecheck && electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "npm run build && electron-builder --dir",
    "build:win": "npm run build && electron-builder --win",
    "build:mac": "npm run build && electron-builder --mac",
    "build:linux": "npm run build && electron-builder --linux",
    "dist": "npm run dist:mac",
    "dist:mac": "npm run dist:mac:release",
    "dist:mac:dev": "npm run build && electron-builder --mac --publish never && npm run verify:mac",
    "dist:mac:release": "npm run release:check-env -- mac && npm run build && electron-builder --mac --config electron-builder.release.yml --publish never && npm run verify:mac:release",
    "dist:win": "npm run release:check-env -- win && npm run build && electron-builder --win --config electron-builder.release.yml --publish never",
    "dist:linux": "npm run release:check-env -- linux && npm run build && electron-builder --linux --config electron-builder.release.yml --publish never"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@tailwindcss/vite": "^4.3.0",
    "better-sqlite3": "^12.9.0",
    "electron-updater": "^6.3.9",
    "react-router-dom": "^7.15.0",
    "recharts": "^3.8.1",
    "systeminformation": "^5.31.6",
    "tailwindcss": "^4.3.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.19.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "electron": "^39.2.6",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "prettier": "^3.7.4",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "typescript": "^5.9.3",
    "vite": "^7.2.6"
  }
}
